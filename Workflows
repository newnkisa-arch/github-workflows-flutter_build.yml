      'Photography tips in golden hour lighting',
      
      // Business & Education
      'Startup pitch presentation animation',
      'Educational science experiment demonstration',
      'Productivity tips for remote work setup',
      'Sustainable living practices showcase',
      'Language learning conversation practice'
    ];
    
    this.categories = {
      'Tech & AI': ['AI', 'robot', 'holographic', 'drone', 'VR', 'autonomous'],
      'Lifestyle': ['cooking', 'workout', 'pet', 'DIY', 'fashion'],
      'Nature': ['sunrise', 'ocean', 'northern lights', 'cherry blossoms', 'wildlife'],
      'Art': ['street art', 'digital art', 'music', 'dance', 'photography'],
      'Education': ['startup', 'science', 'productivity', 'sustainable', 'language']
    };
  }

  // Get trending topics based on simulated popularity
  getTrendingTopics(count = 5) {
    const shuffled = [...this.topics].sort(() => 0.5 - Math.random());
    return shuffled.slice(0, count).map((topic, index) => ({
      id: index,
      text: topic,
      category: this.getTopicCategory(topic),
      popularity: Math.floor(Math.random() * 1000) + 100,
      trending: Math.random() > 0.3
    }));
  }

  // Get topics by category
  getTopicsByCategory(category) {
    const keywords = this.categories[category] || [];
    return this.topics.filter(topic => 
      keywords.some(keyword => topic.toLowerCase().includes(keyword.toLowerCase()))
    );
  }

  // Determine topic category
  getTopicCategory(topic) {
    for (const [category, keywords] of Object.entries(this.categories)) {
      if (keywords.some(keyword => topic.toLowerCase().includes(keyword.toLowerCase()))) {
        return category;
      }
    }
    return 'General';
  }

  // Generate personalized topics based on user preferences
  getPersonalizedTopics(userPreferences = [], count = 5) {
    let filteredTopics = this.topics;
    
    if (userPreferences.length > 0) {
      filteredTopics = this.topics.filter(topic =>
        userPreferences.some(pref => 
          topic.toLowerCase().includes(pref.toLowerCase())
        )
      );
    }
    
    const shuffled = [...filteredTopics].sort(() => 0.5 - Math.random());
    return shuffled.slice(0, count);
  }
}

export default TrendingAlgorithm;
