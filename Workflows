```javascript
import axios from 'axios';

const OPENROUTER_BASE_URL = 'https://openrouter.ai/api/v1';

class OpenRouterAPI {
  constructor(apiKey) {
    this.apiKey = apiKey;
    this.client = axios.create({
      baseURL: OPENROUTER_BASE_URL,
      headers: {
        'Authorization': `Bearer ${apiKey}`,
        'Content-Type': 'application/json',
        'HTTP-Referer': 'https://github.com/newnkisa-arch/main',
        'X-Title': 'OpenRouter Video Generator App'
      }
    });
  }

  // Get available models
  async getModels() {
    try {
      const response = await this.client.get('/models');
      return response.data.data?.filter(model => 
        model.id.includes('video') || 
        model.id.includes('runway') || 
        model.id.includes('pika') ||
        model.id.includes('luma') ||
        model.id.includes('kling') ||
        model.id.includes('minimax') ||
        model.id.includes('haiper')
      ) || this.getFallbackModels();
    } catch (error) {
      console.error('Error fetching models:', error);
      return this.getFallbackModels();
    }
  }

  getFallbackModels() {
    return [
      { id: 'luma/dream-machine', name: 'Luma Dream Machine' },
      { id: 'runway/gen-3-alpha-turbo', name: 'Runway Gen-3 Alpha Turbo' },
      { id: 'pika/pika-1.5', name: 'Pika 1.5' },
      { id: 'minimax/video-01', name: 'MiniMax Video-01' },
      { id: 'haiper/haiper-video-v1.2', name: 'Haiper Video v1.2' }
    ];
  }

  // Generate video
  async generateVideo(prompt, model = 'luma/dream-machine', options = {}) {
    try {
      const response = await this.client.post('/chat/completions', {
        model: model,
        messages: [
          {
            role: 'user',
            content: `Generate a video: ${prompt}`
          }
        ],
        video: {
          aspect_ratio: options.aspectRatio || '16:9',
          duration: options.duration || 5,
          resolution: options.resolution || '720p',
          fps: options.fps || 24
        },
        stream: false
      });

      return response.data;
    } catch (error) {
      throw new Error(`Video generation failed: ${error.response?.data?.error?.message || error.message}`);
    }
  }

  // Enhanced text generation for video scripts
  async generateVideoScript(prompt) {
    try {
      const response = await this.client.post('/chat/completions', {
        model: 'openai/gpt-4-turbo',
        messages: [
          {
            role: 'system',
            content: 'You are a professional video script writer. Create detailed, engaging video scripts with scene descriptions, timing, and visual elements.'
          },
          {
            role: 'user',
            content: `Create a detailed video script for: ${prompt}. Include specific visual descriptions, camera movements, lighting, and timing for a 30-60 second video.`
          }
        ],
        max_tokens: 1500,
        temperature: 0.8
      });

      return response.data.choices[0].message.content;
    } catch (error) {
      throw new Error(`Script generation failed: ${error.message}`);
    }
  }

  // Get account credits/usage
  async getCredits() {
    try {
      const response = await this.client.get('/auth/key');
      return response.data;
    } catch (error) {
      console.error('Error fetching credits:', error);
      return null;
    }
  }
}

export default OpenRouterAPI;
```

