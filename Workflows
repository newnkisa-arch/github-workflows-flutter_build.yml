import React, { useState } from 'react';
import {
  View,
  Text,
  TextInput,
  TouchableOpacity,
  StyleSheet,
  Alert,
  ActivityIndicator
} from 'react-native';

const VideoGenerator = ({ onVideoGenerated, openRouterAPI, selectedModel }) => {
  const [prompt, setPrompt] = useState('');
  const [isGenerating, setIsGenerating] = useState(false);
  const [generationStep, setGenerationStep] = useState('');

  const generateVideo = async () => {
    if (!prompt.trim()) {
      Alert.alert('Error', 'Please enter a video prompt');
      return;
    }

    setIsGenerating(true);
    setGenerationStep('Creating video script...');

    try {
      // Step 1: Generate detailed script
      const script = await openRouterAPI.generateVideoScript(prompt);
      setGenerationStep('Generating video from script...');

      // Step 2: Generate video
      const videoResult = await openRouterAPI.generateVideo(prompt, selectedModel, {
        aspectRatio: '16:9',
        duration: 5,
        resolution: '720p',
        fps: 24
      });

      // For demo purposes, we'll simulate video generation
      // In production, you'd handle the actual video generation response
      setTimeout(() => {
        setGenerationStep('Video ready!');
        onVideoGenerated({
          url: 'https://sample-videos.com/zip/10/mp4/SampleVideo_1280x720_1mb.mp4',
          script: script,
          prompt: prompt,
          model: selectedModel
        });
        setIsGenerating(false);
        setPrompt('');
      }, 3000);

    } catch (error) {
      Alert.alert('Error', error.message);
      setIsGenerating(false);
      setGenerationStep('');
    }
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>✍️ Create Your Video</Text>
      
      <TextInput
        style={styles.input}
        placeholder="Describe your video idea in detail..."
        value={prompt}
        onChangeText={setPrompt}
        multiline
        numberOfLines={4}
        editable={!isGenerating}
      />
      
      <TouchableOpacity
        style={[styles.generateButton, isGenerating && styles.disabledButton]}
        onPress={generateVideo}
        disabled={isGenerating || !prompt.trim()}
      >
        {isGenerating ? (
          <View style={styles.loadingContainer}>
            <ActivityIndicator color="white" />
            <Text style={styles.buttonText}>Generating...</Text>
          </View>
        ) : (
          <Text style={styles.buttonText}>🎬 Generate Video</Text>
        )}
      </TouchableOpacity>

      {isGenerating && (
        <View style={styles.statusContainer}>
          <Text style={styles.statusText}>{generationStep}</Text>
          <Text style={styles.statusSubtext}>This may take 1-3 minutes...</Text>
        </View>
      )}
    </View>
  );
};

